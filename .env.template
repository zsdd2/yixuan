# 商业摄影项目跟进系统 v2.0 环境变量配置模板
# 复制此文件为 .env 并填写实际配置

# ========== 数据库配置 ==========
# PostgreSQL 数据库连接信息
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=photo_studio

# 数据库连接 URL（用于 SQLAlchemy）
# 格式：postgresql+asyncpg://用户名:密码@主机:端口/数据库名
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/photo_studio

# ========== NAS 存储配置 ==========
# NAS 挂载点路径（容器内路径）
# 所有照片文件路径均相对于此目录存储
NAS_MOUNT_PATH=/mnt/nas_data

# ========== 图片处理配置 ==========
# 缩略图最大尺寸（像素）
THUMB_MAX_SIZE=800

# 支持的图片格式（逗号分隔，小写）
SUPPORTED_IMAGE_FORMATS=.jpg,.jpeg,.png,.tif,.tiff,.webp,.heic

# ========== CORS 配置 ==========
# 允许的跨域源（逗号分隔）
# 开发环境
ALLOWED_ORIGINS=http://localhost:15173,http://127.0.0.1:15173
# 生产环境示例（取消注释并修改）
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ========== JWT 认证配置 ==========
# JWT 密钥（用于签名和验证 Token）
# ⚠️ 生产环境必须修改为强随机密钥
# 生成方法：python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-here

# JWT Token 过期时间（分钟）
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# ========== 日志配置 ==========
# 日志级别：DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ========== 应用配置 ==========
# 应用运行端口
PORT=8000

# Python 路径（容器内）
PYTHONPATH=/app
