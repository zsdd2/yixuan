# Yixuan production environment template
# Copy this file to .env before running docker compose in production.

POSTGRES_USER=photo_user
POSTGRES_PASSWORD=change_this_database_password
POSTGRES_DB=photo_tracker
DATABASE_URL=postgresql+asyncpg://photo_user:change_this_database_password@db:5432/photo_tracker

NAS_MOUNT_PATH=/mnt/nas_data
NAS_HOST_PATH=/vol1/docker/yixuan/nas_data
FRONTEND_PORT=15173
ADMIN_USERNAME=admin
ADMIN_PASSWORD=adminadmin
ADMIN_DISPLAY_NAME=超级管理员
# Set to true for one startup only if you need to force-reset the admin password.
ADMIN_RESET_PASSWORD_ON_START=false
# Existing databases keep the current admin password by default.
# If admin/adminadmin returns 401 after deployment, set this to true for one
# restart, log in once, then set it back to false and restart again.

# Generate with:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change_this_to_a_random_secret
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# Use every final LAN/domain address that users open in browser, comma-separated.
# Example: http://192.168.10.166:11111,https://yx.cqlld.top:777
ALLOWED_ORIGINS=http://YOUR_FNNAS_IP:15173

THUMB_MAX_SIZE=800
SUPPORTED_IMAGE_FORMATS=.jpg,.jpeg,.png,.tif,.tiff,.webp,.heic
LOG_LEVEL=INFO
PYTHONPATH=/app
